{
  "expo": {
    "name": "FileTrail",
    "slug": "filetrail",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F12"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.papertraill.app",
      "infoPlist": {
        "NSCameraUsageDescription": "FileTrail uses your camera to scan documents.",
        "NSPhotoLibraryUsageDescription": "FileTrail accesses your photos to import documents.",
        "NSFaceIDUsageDescription": "FileTrail uses Face ID to protect your vault."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F12"
      },
      "package": "com.papertraill.app",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-local-authentication",
      "expo-dev-client",
      [
        "expo-camera",
        {
          "cameraPermission": "FileTrail uses your camera to scan documents.",
          "recordAudioAndroid": false
        }
      ],
      "react-native-pdf",
      "react-native-blob-util"
    ],
    "scheme": "filetrail",
    "experiments": {
      "typedRoutes": true
    }
  }
}
