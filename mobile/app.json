{
  "expo": {
    "name": "FileTrail",
    "slug": "filetrail",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "web": {
      "favicon": "./assets/icon.png"
    },
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F12"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.papertraill.app",
      "buildNumber": "2",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "FileTrail uses your camera to scan documents.",
        "NSPhotoLibraryUsageDescription": "FileTrail accesses your photos to import documents.",
        "NSFaceIDUsageDescription": "FileTrail uses Face ID to protect your vault.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F12"
      },
      "package": "com.papertraill.app",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-local-authentication",
      [
        "expo-image-picker",
        {
          "cameraPermission": "FileTrail uses your camera to scan documents.",
          "photosPermission": "FileTrail accesses your photos to import documents.",
          "microphonePermission": false
        }
      ],
      "expo-font"
    ],
    "scheme": "filetrail",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "b2a80367-e836-4bf3-9399-c9aa055294da"
      }
    }
  }
}
