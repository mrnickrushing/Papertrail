{
  "expo": {
    "name": "PaperTrail",
    "slug": "papertrail",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F12"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nitehawk.papertrail",
      "infoPlist": {
        "NSCameraUsageDescription": "PaperTrail uses your camera to scan documents.",
        "NSPhotoLibraryUsageDescription": "PaperTrail accesses your photos to import documents.",
        "NSFaceIDUsageDescription": "PaperTrail uses Face ID to protect your vault."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F12"
      },
      "package": "com.nitehawk.papertrail",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-local-authentication",
      "expo-dev-client",
      [
        "expo-camera",
        { "cameraPermission": "PaperTrail uses your camera to scan documents." }
      ],
      [
        "@config-plugins/react-native-pdf",
        {}
      ],
      [
        "@config-plugins/react-native-blob-util",
        {}
      ]
    ],
    "scheme": "papertrail",
    "experiments": {
      "typedRoutes": true
    }
  }
}
