# PaperTrail Backend
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Comma-separated list, for example:
# CORS_ORIGINS=http://localhost:8081,exp://127.0.0.1:8081
CORS_ORIGINS=*

# Optional shared secret. When set, clients must send:
# Authorization: Bearer <API_KEY>
API_KEY=

# Local development persistence. In production, replace with Supabase/R2 adapters.
DATA_DIR=.data
PUBLIC_APP_URL=http://localhost:4000

# Railway Postgres. Railway injects this when a Postgres service is attached.
DATABASE_URL=

# Planned Pro integrations
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
OPENAI_API_KEY=
POSTMARK_INBOUND_TOKEN=
